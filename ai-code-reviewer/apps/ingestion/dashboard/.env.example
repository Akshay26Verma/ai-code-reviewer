PORT=3004
NODE_ENV=development

# NextAuth
NEXTAUTH_URL=http://localhost:3004
NEXTAUTH_SECRET=your-nextauth-secret-min-32-chars

# GitHub OAuth App — register at https://github.com/settings/developers
# Callback URL: http://localhost:3004/api/auth/callback/github
GITHUB_CLIENT_ID=your-github-oauth-app-client-id
GITHUB_CLIENT_SECRET=your-github-oauth-app-client-secret

# Must match api-gateway JWT_SECRET exactly
JWT_SECRET=your-jwt-secret-min-32-chars

# api-gateway base URL (use http://api-gateway:3003 inside Docker)
API_GATEWAY_URL=http://localhost:3003
