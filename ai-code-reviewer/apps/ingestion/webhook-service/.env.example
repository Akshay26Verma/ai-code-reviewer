PORT=3002
NODE_ENV=development

# Kafka
KAFKA_BROKERS=localhost:9092
KAFKA_CLIENT_ID=webhook-service-client

# GitHub App credentials
GITHUB_WEBHOOK_SECRET=your-github-webhook-secret
GITHUB_APP_ID=123456
# base64-encode your PEM: base64 -w 0 private-key.pem
GITHUB_APP_PRIVATE_KEY=base64-encoded-private-key-pem

# GitLab credentials
GITLAB_WEBHOOK_SECRET=your-gitlab-webhook-secret
GITLAB_TOKEN=your-gitlab-project-or-group-token
# Optional: override for self-hosted GitLab
GITLAB_URL=https://gitlab.com
