# ──────────────────────────────────────────────────────────────────────
# LLM Gateway Configuration
# 
# This is the ONLY file you need to update to switch providers or keys.
# Copy this to .env and fill in your real values.
# ──────────────────────────────────────────────────────────────────────

# ── App ──────────────────────────────────────────────────────────────
APP_NAME=llm-gateway
APP_VERSION=0.1.0
DEBUG=false

# ── Default LLM Provider ────────────────────────────────────────────
# This is the default provider used when routing.yaml doesn't specify one.
# Supported: groq, openai, anthropic, azure, bedrock, etc.
LLM_PROVIDER=groq
LLM_MODEL=llama-3.1-8b-instant

# ── Provider API Keys ───────────────────────────────────────────────
# LiteLLM reads these automatically based on the provider name.
# Only fill in the keys for providers you actually use.
LLM_API_KEY=sk-mock-key-replace-me
OPENAI_API_KEY=sk-mock-openai-key
ANTHROPIC_API_KEY=sk-mock-anthropic-key
GROQ_API_KEY=sk-mock-groq-key

# ── Model Version (cache invalidation) ─────────────────────────────
# Bump this when you change providers/models to auto-invalidate cache.
MODEL_VERSION=v1

# ── Redis (shared instance — namespaced with key prefix) ────────────
REDIS_URL=redis://localhost:6379/0
CACHE_TTL_SECONDS=3600
CACHE_KEY_PREFIX=llm-gw:cache

# ── Routing Config ──────────────────────────────────────────────────
ROUTING_CONFIG_PATH=app/routing.yaml

# ── Server ──────────────────────────────────────────────────────────
HOST=0.0.0.0
PORT=8000
