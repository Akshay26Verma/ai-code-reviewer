# ──────────────────────────────────────────────────────────────────────
# Code Indexer Configuration
# ──────────────────────────────────────────────────────────────────────

# ── App ──────────────────────────────────────────────────────────────
PORT=3000
NODE_ENV=development

# ── Kafka ────────────────────────────────────────────────────────────
KAFKA_BROKERS=localhost:9092
KAFKA_CLIENT_ID=code-indexer-client
KAFKA_GROUP_ID=code-indexer-group

# ── Pinecone ─────────────────────────────────────────────────────────
PINECONE_API_KEY=mock-pinecone-key
PINECONE_INDEX=ai-code-reviewer

# ── AWS S3 (Artifact Storage) ────────────────────────────────────────
AWS_REGION=us-east-1
AWS_ACCESS_KEY_ID=mock-access-key
AWS_SECRET_ACCESS_KEY=mock-secret-key
S3_BUCKET_NAME=ai-code-reviewer-artifacts
S3_ENDPOINT=http://localhost:4566

# ── Internal Service URLs ────────────────────────────────────────────
LLM_GATEWAY_URL=http://localhost:8000
KNOWLEDGE_GRAPH_URL=http://localhost:3001
