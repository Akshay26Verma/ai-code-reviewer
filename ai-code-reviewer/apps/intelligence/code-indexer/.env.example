# ──────────────────────────────────────────────────────────────────────
# Code Indexer Configuration
# ──────────────────────────────────────────────────────────────────────

# ── App ──────────────────────────────────────────────────────────────
PORT=3000
NODE_ENV=development

# ── Kafka ────────────────────────────────────────────────────────────
KAFKA_BROKERS=your-kafka-brokers
KAFKA_CLIENT_ID=code-indexer-client
KAFKA_GROUP_ID=code-indexer-group

# ── Pinecone ─────────────────────────────────────────────────────────
PINECONE_API_KEY=your-pinecone-api-key
PINECONE_INDEX=ai-code-reviewer
VOYAGE_API_KEY=your-voyage-api-key

# ── AWS S3 (Artifact Storage) ────────────────────────────────────────
AWS_REGION=us-east-1
AWS_ACCESS_KEY_ID=your-aws-access-key-id
AWS_SECRET_ACCESS_KEY=your-aws-secret-access-key
S3_BUCKET_NAME=ai-code-reviewer-artifacts
S3_ENDPOINT=your-s3-endpoint

# ── Internal Service URLs ────────────────────────────────────────────
BIFROST_URL=your-bifrost-url
KNOWLEDGE_GRAPH_URL=your-knowledge-graph-url
