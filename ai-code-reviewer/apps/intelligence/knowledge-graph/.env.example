# ──────────────────────────────────────────────────────────────────────
# Knowledge Graph Configuration
# ──────────────────────────────────────────────────────────────────────

# ── App ──────────────────────────────────────────────────────────────
PORT=3001
NODE_ENV=development

# ── Neo4j ────────────────────────────────────────────────────────────
NEO4J_URI=bolt://neo4j:7687
NEO4J_USERNAME=neo4j
NEO4J_PASSWORD=password

# ── Redis (Query Cache) ───────────────────────────────────────────────
REDIS_URL=redis://redis:6379
KG_CACHE_TTL=60
