# ──────────────────────────────────────────────────────────────────────
# Knowledge Graph Configuration
# ──────────────────────────────────────────────────────────────────────

# ── App ──────────────────────────────────────────────────────────────
PORT=3001
NODE_ENV=development

# ── Neo4j (AuraDB) ───────────────────────────────────────────────────
NEO4J_URI=your-neo4j-uri
NEO4J_USERNAME=your-neo4j-username
NEO4J_PASSWORD=your-neo4j-password

# ── Redis (Query Cache) ───────────────────────────────────────────────
REDIS_URL=your-redis-url
KG_CACHE_TTL=60
